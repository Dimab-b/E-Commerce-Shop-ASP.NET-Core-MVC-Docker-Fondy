
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Интернет-магазин</title>
    <link rel="stylesheet" href="~/css/site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js"></script>
</head>

<body>
    <header class="headik">
        <span class="logo">Best Shop</span>
        <nav>
            <a href="/"> Головна сторінка </a>
            <a href="/home/about">Про нас</a>
            <a href="/blog">Блог</a>
            <partial name="_LoginPartial" />

        </nav>
    </header>
    <h1 class="main_title">@ViewData["H1"] </h1>


  




    <main class="items">
        @RenderBody()
    </main>



    <a href="/cart">
        <button class="shop-cart-button"><i class="fas fa-shopping-cart"></i></button>
    </a>

    <footer>Всі права захищені &copy;</footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>